# Copy to .env and adjust. All values have safe dev defaults, so .env is optional.

ENVIRONMENT=development

# Dev default is async SQLite (no infra). For Postgres (see ../docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://luma:luma@localhost:5432/luma
DATABASE_URL=sqlite+aiosqlite:///./luma.db

# Change this in production.
SECRET_KEY=dev-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma/JSON list of allowed frontend origins.
CORS_ORIGINS=["http://localhost:3000"]

# Optional — enables Google OAuth when set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000
