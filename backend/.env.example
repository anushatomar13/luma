# Copy to .env and fill in the keys you have. Everything has a safe fallback, so
# the app runs fully without any of these — add a key to turn on real data.

ENVIRONMENT=development

# --- Core ---
# Dev default is SQLite (no infra). For Postgres (see ../docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://luma:luma@localhost:5432/luma
DATABASE_URL=sqlite+aiosqlite:///./luma.db
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000

# --- AI: Google Gemini (get a key at https://aistudio.google.com/apikey) ---
# Set this to turn on real AI insights + real semantic search. That's all it needs.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Spotify (https://developer.spotify.com/dashboard) ---
# In the Spotify app, add this exact Redirect URI (use 127.0.0.1, NOT localhost):
#   http://127.0.0.1:8000/api/v1/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/spotify/callback

# --- Google login (optional; email/password works without it) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# --- Background jobs (optional) ---
# Leave unset to run jobs in-process. If you set REDIS_URL you MUST also run a
# Celery worker (`celery -A app.worker.celery_app worker`) or jobs never execute.
# REDIS_URL=redis://localhost:6379/0
