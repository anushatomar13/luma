# Root-level ignores (frontend/ has its own .gitignore for Node/Next artifacts)

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Env / secrets
.env
.env.*
!.env.example

# Python (backend / ai — populated in later phases)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Logs
*.log
